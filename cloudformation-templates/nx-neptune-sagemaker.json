{
  "Description": "Creates a Neptune Analytics graph and SageMaker notebook with nx-neptune pre-installed",
  "Parameters": {
    "ApplicationId": {
      "Description": "Application id (used to name all resources)",
      "Type": "String",
      "Default": "nx-neptune",
      "AllowedPattern": "[a-z][a-z0-9-]*",
      "MaxLength": 16,
      "MinLength": 3
    },
    "ProvisionedMemory": {
      "Description": "Number of m-NCUs to allocate to the graph",
      "Type": "String",
      "Default": "16",
      "AllowedValues": ["16", "32", "64"]
    },
    "PublicConnectivity": {
      "Description": "Enable public connectivity for the graph",
      "Type": "String",
      "Default": "true",
      "AllowedValues": ["true", "false"]
    },
    "NotebookInstanceType": {
      "Description": "SageMaker notebook instance type",
      "Type": "String",
      "Default": "ml.t3.medium"
    },
    "AssetsS3Prefix": {
      "Description": "S3 prefix containing notebooks.zip and optionally a .whl file (e.g. s3://bucket/prefix). Required when NotebookSource is s3.",
      "Type": "String",
      "Default": "",
      "AllowedPattern": "(s3://.+|)"
    },
    "NotebookSource": {
      "Description": "Where to fetch notebooks from: s3 (requires AssetsS3Prefix) or release (downloads from GitHub Releases)",
      "Type": "String",
      "Default": "release",
      "AllowedValues": ["s3", "release"]
    }
  },
  "Conditions": {
    "UseS3Source": { "Fn::Equals": [{ "Ref": "NotebookSource" }, "s3"] }
  },
  "Resources": {
    "Graph": {
      "Type": "AWS::NeptuneGraph::Graph",
      "Properties": {
        "GraphName": { "Fn::Sub": "${ApplicationId}-graph" },
        "DeletionProtection": false,
        "ProvisionedMemory": { "Ref": "ProvisionedMemory" },
        "PublicConnectivity": { "Ref": "PublicConnectivity" },
        "Tags": [
          { "Key": "Name", "Value": { "Fn::Sub": "${ApplicationId}-graph" } },
          { "Key": "Stack", "Value": { "Fn::Sub": "${AWS::Region}-${AWS::StackName}" } }
        ]
      }
    },
    "S3BucketKey": {
      "Type": "AWS::KMS::Key",
      "Properties": {
        "Description": { "Fn::Sub": "KMS key for ${ApplicationId} S3 bucket" },
        "KeyPolicy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowRootAccount",
              "Effect": "Allow",
              "Principal": { "AWS": { "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root" } },
              "Action": "kms:*",
              "Resource": "*"
            },
            {
              "Sid": "AllowNotebookRole",
              "Effect": "Allow",
              "Principal": { "AWS": { "Fn::GetAtt": ["NotebookRole", "Arn"] } },
              "Action": ["kms:Decrypt", "kms:GenerateDataKey", "kms:DescribeKey"],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "StagingBucket": {
      "Type": "AWS::S3::Bucket",
      "DeletionPolicy": "Delete",
      "Properties": {
        "BucketName": { "Fn::Sub": "${ApplicationId}-staging-${AWS::AccountId}-${AWS::Region}" },
        "VersioningConfiguration": {
          "Status": "Enabled"
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "aws:kms",
                "KMSMasterKeyID": { "Fn::GetAtt": ["S3BucketKey", "Arn"] }
              },
              "BucketKeyEnabled": true
            }
          ]
        },
        "Tags": [
          { "Key": "Stack", "Value": { "Fn::Sub": "${AWS::Region}-${AWS::StackName}" } }
        ]
      }
    },
    "NotebookRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": { "Service": "sagemaker.amazonaws.com" },
              "Action": "sts:AssumeRole"
            },
            {
              "Effect": "Allow",
              "Principal": { "Service": "neptune-graph.amazonaws.com" },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Path": "/"
      }
    },
    "NeptuneAccessPolicy": {
      "Type": "AWS::IAM::ManagedPolicy",
      "Properties": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "NeptuneGraphOps",
              "Effect": "Allow",
              "Action": [
                "neptune-graph:ReadDataViaQuery",
                "neptune-graph:WriteDataViaQuery",
                "neptune-graph:DeleteDataViaQuery",
                "neptune-graph:GetGraph",
                "neptune-graph:ListGraphs",
                "neptune-graph:ResetGraph",
                "neptune-graph:CreateGraph",
                "neptune-graph:CreateGraphUsingImportTask",
                "neptune-graph:DeleteGraph",
                "neptune-graph:UpdateGraph",
                "neptune-graph:StartGraph",
                "neptune-graph:StopGraph",
                "neptune-graph:TagResource"
              ],
              "Resource": "*"
            },
            {
              "Sid": "NeptuneImportExportTasks",
              "Effect": "Allow",
              "Action": [
                "neptune-graph:StartImportTask",
                "neptune-graph:GetImportTask",
                "neptune-graph:StartExportTask",
                "neptune-graph:GetExportTask"
              ],
              "Resource": [
                { "Fn::Sub": "arn:${AWS::Partition}:neptune-graph:${AWS::Region}:${AWS::AccountId}:graph/*" },
                { "Fn::Sub": "arn:${AWS::Partition}:neptune-graph:${AWS::Region}:${AWS::AccountId}:import-task/*" },
                { "Fn::Sub": "arn:${AWS::Partition}:neptune-graph:${AWS::Region}:${AWS::AccountId}:export-task/*" }
              ]
            },
            {
              "Sid": "NeptuneSnapshots",
              "Effect": "Allow",
              "Action": [
                "neptune-graph:CreateGraphSnapshot",
                "neptune-graph:DeleteGraphSnapshot",
                "neptune-graph:GetGraphSnapshot",
                "neptune-graph:RestoreGraphFromSnapshot",
                "neptune-graph:TagResource"
              ],
              "Resource": "*"
            },
            {
              "Sid": "CloudWatchLogs",
              "Effect": "Allow",
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
              ],
              "Resource": {
                "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/sagemaker/*"
              }
            },
            {
              "Sid": "SageMakerDescribe",
              "Effect": "Allow",
              "Action": "sagemaker:DescribeNotebookInstance",
              "Resource": {
                "Fn::Sub": "arn:${AWS::Partition}:sagemaker:${AWS::Region}:${AWS::AccountId}:notebook-instance/aws-neptune-${ApplicationId}"
              }
            },
            {
              "Sid": "S3AssetDownload",
              "Effect": "Allow",
              "Action": ["s3:GetObject", "s3:ListBucket"],
              "Resource": [
                { "Fn::If": ["UseS3Source",
                  { "Fn::Sub": [
                    "arn:aws:s3:::${bucket}",
                    { "bucket": { "Fn::Select": [0, { "Fn::Split": ["/", { "Fn::Select": [1, { "Fn::Split": ["s3://", { "Ref": "AssetsS3Prefix" }] }] }] }] } }
                  ]},
                  { "Ref": "AWS::NoValue" }
                ]},
                { "Fn::If": ["UseS3Source",
                  { "Fn::Sub": [
                    "arn:aws:s3:::${bucket}/*",
                    { "bucket": { "Fn::Select": [0, { "Fn::Split": ["/", { "Fn::Select": [1, { "Fn::Split": ["s3://", { "Ref": "AssetsS3Prefix" }] }] }] }] } }
                  ]},
                  { "Ref": "AWS::NoValue" }
                ]},
                { "Fn::Sub": "arn:aws:s3:::aws-neptune-notebook-${AWS::Region}" },
                { "Fn::Sub": "arn:aws:s3:::aws-neptune-notebook-${AWS::Region}/*" }
              ]
            },
            {
              "Sid": "S3ImportExport",
              "Effect": "Allow",
              "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:ListBucket",
                "s3:GetBucketVersioning",
                "s3:GetEncryptionConfiguration",
                "s3:GetBucketLocation"
              ],
              "Resource": [
                { "Fn::Sub": "arn:aws:s3:::${StagingBucket}" },
                { "Fn::Sub": "arn:aws:s3:::${StagingBucket}/*" }
              ]
            },
            {
              "Sid": "PassRoleToNeptune",
              "Effect": "Allow",
              "Action": ["iam:PassRole", "iam:GetRole", "iam:SimulatePrincipalPolicy"],
              "Resource": { "Fn::GetAtt": ["NotebookRole", "Arn"] }
            },
            {
              "Sid": "AthenaQueryExecution",
              "Effect": "Allow",
              "Action": ["athena:StartQueryExecution", "athena:GetQueryExecution", "athena:GetQueryResults"],
              "Resource": "*"
            },
            {
              "Sid": "GlueDataCatalog",
              "Effect": "Allow",
              "Action": [
                "glue:GetDatabase",
                "glue:GetTable",
                "glue:GetTables",
                "glue:CreateTable",
                "glue:UpdateTable",
                "glue:DeleteTable",
                "glue:GetPartitions",
                "glue:CreateDatabase"
              ],
              "Resource": [
                { "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:catalog" },
                { "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:database/*" },
                { "Fn::Sub": "arn:aws:glue:${AWS::Region}:${AWS::AccountId}:table/*" }
              ]
            },
            {
              "Sid": "KMSAccess",
              "Effect": "Allow",
              "Action": [
                "kms:Decrypt",
                "kms:GenerateDataKey",
                "kms:DescribeKey"
              ],
              "Resource": { "Fn::GetAtt": ["S3BucketKey", "Arn"] }
            }
          ]
        },
        "Roles": [{ "Ref": "NotebookRole" }],
        "Path": "/"
      }
    },
    "NotebookLifecycleConfig": {
      "Type": "AWS::SageMaker::NotebookInstanceLifecycleConfig",
      "Properties": {
        "OnCreate": [
          {
            "Content": {
              "Fn::Base64": {
                "Fn::Join": [
                  "",
                  [
                    "#!/bin/bash\n",
                    "set -e\n",
                    "sudo -u ec2-user -i <<'EOF'\n",
                    "source /home/ec2-user/anaconda3/bin/activate python3\n",
                    "NOTEBOOK_SOURCE=\"", { "Ref": "NotebookSource" }, "\"\n",
                    "ASSETS_PREFIX=\"", { "Ref": "AssetsS3Prefix" }, "\"\n",
                    "mkdir -p /home/ec2-user/SageMaker/.nx-neptune\n",
                    "if [ \"$NOTEBOOK_SOURCE\" = \"s3\" ]; then\n",
                    "  aws s3 cp \"${ASSETS_PREFIX%/}/\" /tmp/nx-assets/ --recursive --exclude '*' --include '*.whl' --include 'notebooks.zip'\n",
                    "  if ls /tmp/nx-assets/*.whl 1>/dev/null 2>&1; then\n",
                    "    cp /tmp/nx-assets/*.whl /home/ec2-user/SageMaker/.nx-neptune/\n",
                    "    pip install /home/ec2-user/SageMaker/.nx-neptune/*.whl\n",
                    "  else\n",
                    "    pip install nx_neptune\n",
                    "  fi\n",
                    "  if [ -f /tmp/nx-assets/notebooks.zip ]; then\n",
                    "    unzip -o /tmp/nx-assets/notebooks.zip -d /home/ec2-user/SageMaker\n",
                    "  fi\n",
                    "  rm -rf /tmp/nx-assets\n",
                    "else\n",
                    "  pip install nx_neptune\n",
                    "  curl -sL https://github.com/awslabs/nx-neptune/releases/latest/download/notebooks.zip -o /tmp/notebooks.zip\n",
                    "  unzip -o /tmp/notebooks.zip -d /home/ec2-user/SageMaker/notebooks\n",
                    "  rm -f /tmp/notebooks.zip\n",
                    "fi\n",
                    "pip install graph-notebook\n",
                    "python -m ipykernel install --user --name python3 --display-name 'Python 3 (ipykernel)'\n",
                    "conda deactivate\n",
                    "EOF"
                  ]
                ]
              }
            }
          }
        ],
        "OnStart": [
          {
            "Content": {
              "Fn::Base64": {
                "Fn::Join": [
                  "",
                  [
                    "#!/bin/bash\n",
                    "set -e\n",
                    "# Install nx_neptune in conda python3 env\n",
                    "sudo -u ec2-user -i bash -c 'source /home/ec2-user/anaconda3/bin/activate python3 && if ls /home/ec2-user/SageMaker/.nx-neptune/*.whl 1>/dev/null 2>&1; then pip install -q /home/ec2-user/SageMaker/.nx-neptune/*.whl; else pip install -q nx_neptune; fi'\n",
                    "# Install Neptune notebook tooling (magic commands, JupyterLab extensions)\n",
                    "sudo -u ec2-user -i <<'EOF'\n",
                    "echo \"export GRAPH_NOTEBOOK_AUTH_MODE=IAM\" >> ~/.bashrc\n",
                    "echo \"export GRAPH_NOTEBOOK_SSL=True\" >> ~/.bashrc\n",
                    "echo \"export GRAPH_NOTEBOOK_SERVICE=neptune-graph\" >> ~/.bashrc\n",
                    "echo \"export GRAPH_NOTEBOOK_HOST=", { "Fn::GetAtt": ["Graph", "Endpoint"] }, "\" >> ~/.bashrc\n",
                    "echo \"export GRAPH_NOTEBOOK_PORT=8182\" >> ~/.bashrc\n",
                    "echo \"export AWS_REGION=", { "Ref": "AWS::Region" }, "\" >> ~/.bashrc\n",
                    "source ~/.bashrc\n",
                    "aws s3 cp s3://", { "Fn::Sub": "aws-neptune-notebook-${AWS::Region}" }, "/graph_notebook.tar.gz /tmp/graph_notebook.tar.gz\n",
                    "rm -rf /tmp/graph_notebook\n",
                    "tar -zxvf /tmp/graph_notebook.tar.gz -C /tmp\n",
                    "/tmp/graph_notebook/install_jl4x.sh\n",
                    "EOF\n",
                    "# Set env vars via os.environ so all child processes (kernels) inherit them\n",
                    "cat >> /home/ec2-user/.jupyter/jupyter_notebook_config.py <<ENVEOF\n",
                    "import os\n",
                    "os.environ['NETWORKX_GRAPH_ID'] = '", { "Fn::GetAtt": ["Graph", "GraphId"] }, "'\n",
                    "os.environ['AWS_REGION'] = '", { "Ref": "AWS::Region" }, "'\n",
                    "os.environ['NETWORKX_S3_EXPORT_BUCKET_PATH'] = 's3://",
                    { "Ref": "StagingBucket" },
                    "/export/'\n",
                    "os.environ['NETWORKX_S3_IMPORT_BUCKET_PATH'] = 's3://",
                    { "Ref": "StagingBucket" },
                    "/import/'\n",
                    "os.environ['NETWORKX_STAGING_BUCKET'] = 's3://",
                    { "Ref": "StagingBucket" },
                    "'\n",
                    "os.environ['NETWORKX_S3_TABLES_CATALOG'] = 'AwsDataCatalog'\n",
                    "os.environ['NETWORKX_S3_TABLES_DATABASE'] = 'default'\n",
                    "os.environ['NETWORKX_S3_TABLES_TABLENAME'] = 'paysim_transactions'\n",
                    "ENVEOF\n",
                    "# Restart jupyter to pick up the config\n",
                    "initctl restart jupyter-server --no-wait 2>/dev/null || systemctl restart jupyter-server 2>/dev/null || true\n"
                  ]
                ]
              }
            }
          }
        ]
      }
    },
    "NotebookInstance": {
      "Type": "AWS::SageMaker::NotebookInstance",
      "Properties": {
        "InstanceType": { "Ref": "NotebookInstanceType" },
        "PlatformIdentifier": "notebook-al2-v3",
        "NotebookInstanceName": { "Fn::Sub": "aws-neptune-${ApplicationId}" },
        "RoleArn": { "Fn::GetAtt": ["NotebookRole", "Arn"] },
        "LifecycleConfigName": {
          "Fn::GetAtt": ["NotebookLifecycleConfig", "NotebookInstanceLifecycleConfigName"]
        },
        "Tags": [
          { "Key": "Stack", "Value": { "Fn::Sub": "${AWS::Region}-${AWS::StackName}" } },
          { "Key": "Application", "Value": { "Fn::Sub": "nx-neptune:${ApplicationId}" } }
        ]
      }
    }
  },
  "Outputs": {
    "GraphId": {
      "Description": "Neptune Analytics Graph ID",
      "Value": { "Fn::GetAtt": ["Graph", "GraphId"] }
    },
    "NotebookURL": {
      "Description": "SageMaker notebook URL",
      "Value": {
        "Fn::Join": [
          "",
          [
            "https://",
            {
              "Fn::Select": [
                1,
                { "Fn::Split": ["/", { "Ref": "NotebookInstance" }] }
              ]
            },
            ".notebook.",
            { "Ref": "AWS::Region" },
            ".sagemaker.aws/nbclassic/tree"
          ]
        ]
      }
    },
    "StagingBucketName": {
      "Description": "S3 bucket for import/export, datasets, Athena results, and general use",
      "Value": { "Ref": "StagingBucket" }
    }
  }
}
